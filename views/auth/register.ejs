<%- layout('boilerplate') %>

<!-- Registration Terminal Canvas Wrapper -->
<div
  class="d-flex flex-column flex-grow-1 w-100 py-5 justify-content-center align-items-center"
  style="background-color: #0f172a"
>
  <div
    class="card p-4 border border-secondary border-opacity-20 text-white font-monospace shadow"
    style="background-color: #1e293b; width: 100%; max-width: 420px"
  >
    <!-- Code Terminal Header Row -->
    <div
      class="d-flex align-items-center gap-1.5 border-b pb-2 mb-4 border-secondary border-opacity-20"
      style="border-bottom: 1px solid #334155"
    >
      <span
        class="rounded-circle bg-info d-inline-block"
        style="width: 8px; height: 8px"
      ></span>
      <span class="text-info small ms-2" style="font-size: 0.8rem"
        >// INITIALIZE_NEW_OPERATOR</span
      >
    </div>

    <form action="/register" method="POST" class="needs-validation" novalidate>
      <!-- Handle Username Box Input -->
      <div class="mb-3">
        <label for="username" class="form-label small text-secondary fw-bold"
          >1. ALLOCATE_HANDLE_ID</label
        >
        <input
          type="text"
          id="username"
          name="username"
          class="form-control bg-dark border-secondary border-opacity-30 text-white font-monospace"
          placeholder="e.g., deepak"
          required
          style="background-color: #0b1329 !important"
        />
        <div
          class="invalid-feedback font-monospace small text-danger mt-1"
          style="font-size: 0.7rem"
        >
          [CRITICAL] Username signature identity token is mandatory.
        </div>
      </div>

      <!-- Passcode Secure Input Box -->
      <div class="mb-4">
        <label for="password" class="form-label small text-secondary fw-bold"
          >2. SECURITY_HASH_PASSCODE</label
        >
        <input
          type="password"
          id="password"
          name="password"
          class="form-control bg-dark border-secondary border-opacity-30 text-white font-monospace"
          placeholder="••••••••"
          required
          style="background-color: #0b1329 !important"
        />
        <div
          class="invalid-feedback font-monospace small text-danger mt-1"
          style="font-size: 0.7rem"
        >
          [CRITICAL] Account compilation requires a password passcode.
        </div>
      </div>

      <!-- Form Processing Executive Trigger -->
      <button
        type="submit"
        class="btn btn-info w-100 fw-bold text-dark font-monospace mb-3 py-2"
      >
        COMPILE_ACCOUNT &rarr;
      </button>
    </form>

    <!-- Redirect Navigation Frame Footer -->
    <div class="mt-3 text-center" style="font-size: 0.8rem">
      <a
        href="/login"
        class="text-secondary text-decoration-none hover-underline"
        >// Active operator? Execute standard login instead.</a
      >
    </div>
  </div>
</div>

<!-- Inline Hover Validation Patch UI Override -->
<style>
  .hover-underline:hover {
    color: #38bdf8 !important;
    text-decoration: underline !important;
  }
</style>
