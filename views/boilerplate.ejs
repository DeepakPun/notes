<!DOCTYPE html>
<html lang="en" class="h-100">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Notes Matrix Engine // V1.0</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/css/custom.css" />
    <style>
      /* Force the absolute canvas baseline to stay slate dark */
      html,
      body {
        background-color: #0f172a !important; /* Slate 900 */
        color: #cbd5e1 !important; /* Slate 300 */
        margin: 0 !important;
        padding: 0 !important;
      }
      /* Lock down background continuity across layout boundaries */
      .navbar,
      main,
      footer {
        background-color: inherit;
      }
      .note-card {
        transition:
          transform 0.15s ease,
          box-shadow 0.15s ease;
        border-left: 4px solid #38bdf8 !important; /* Cyber Sky Blue Indicator */
      }
      .note-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
      }
    </style>
  </head>
  <body class="d-flex flex-column min-vh-100">
    <%- include('./partials/navbar') %> <%- include('./partials/flash') %>

    <main class="d-flex flex-column flex-grow-1 w-100"><%- body %></main>

    <%- include('./partials/footer') %>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js"
      integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y"
      crossorigin="anonymous"
    ></script>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <script src="/js/util.js"></script>
  </body>
</html>
