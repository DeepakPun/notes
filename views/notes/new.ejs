<%- layout('boilerplate') %>

<div
  class="d-flex flex-column flex-grow-1 w-100 py-5"
  style="background-color: #0f172a"
>
  <div class="container text-white" style="max-width: 800px">
    <div class="mb-4 border-bottom border-secondary border-opacity-20 pb-3">
      <h1 class="h3 font-monospace text-info">// ALLOCATE_NEW_NOTE_NODE</h1>
    </div>

    <form
      action="/notes"
      method="POST"
      class="p-4 rounded border border-secondary border-opacity-20"
      style="background-color: #1e293b"
    >
      <!-- Grid Row for Folder and Title -->
      <div class="row g-3 mb-3">
        <div class="col-md-8">
          <label class="form-label font-monospace small text-secondary"
            >NODE_TITLE</label
          >
          <input
            type="text"
            name="title"
            class="form-control bg-dark border-secondary text-white font-monospace"
            placeholder="e.g., React.js Core Architecture"
            required
          />
        </div>
        <div class="col-md-4">
          <label class="form-label font-monospace small text-secondary"
            >FOLDER_NAME</label
          >
          <input
            type="text"
            name="folderName"
            class="form-control bg-dark border-secondary text-white font-monospace"
            placeholder="e.g., Frontend"
          />
        </div>
      </div>

      <!-- Core Context Definition -->
      <div class="mb-3">
        <label class="form-label font-monospace small text-secondary"
          >CORE_DEFINITION_OVERVIEW</label
        >
        <textarea
          name="content"
          class="form-control bg-dark border-secondary text-white"
          rows="3"
          placeholder="Provide the core high-level explanation..."
          required
        ></textarea>
      </div>

      <!-- 🚀 EXTENSION FIELDS -->
      <div class="mb-3">
        <label class="form-label font-monospace small text-secondary"
          >CORE_FEATURES_HIGHLIGHTS (Separated by commas)</label
        >
        <input
          type="text"
          name="coreFeatures"
          class="form-control bg-dark border-secondary text-white font-monospace"
          placeholder="Component-Based, Virtual DOM, Unidirectional Flow"
        />
      </div>

      <div class="mb-3">
        <label class="form-label font-monospace small text-secondary"
          >ARCHITECTURAL_USE_CASE</label
        >
        <input
          type="text"
          name="useCase"
          class="form-control bg-dark border-secondary text-white font-monospace"
          placeholder="When to use this module? e.g., High-performance data-driven SPAs"
        />
      </div>

      <div class="mb-3">
        <label class="form-label font-monospace small text-secondary"
          >QUICK_REFERENCE_SYNTAX (Code block code string)</label
        >
        <textarea
          name="codeSnippet"
          class="form-control bg-dark border-secondary text-success font-monospace"
          rows="4"
          placeholder="const App = () => { return <h1>Hello Matrix</h1> }"
        ></textarea>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <label class="form-label font-monospace small text-secondary"
            >TAXONOMY_TAGS (Separated by commas)</label
          >
          <input
            type="text"
            name="tags"
            class="form-control bg-dark border-secondary text-white font-monospace"
            placeholder="javascript, UI, web"
          />
        </div>
        <div class="col-md-6">
          <label class="form-label font-monospace small text-secondary"
            >OFFICIAL_DOCUMENTATION_URL</label
          >
          <input
            type="url"
            name="officialDocs"
            class="form-control bg-dark border-secondary text-white font-monospace"
            placeholder="https://react.dev"
          />
        </div>
      </div>

      <!-- Execution Controllers -->
      <div class="d-flex gap-2 justify-content-end">
        <a
          href="/notes"
          class="btn btn-outline-secondary font-monospace btn-sm px-3"
          >CANCEL</a
        >
        <button
          type="submit"
          class="btn btn-info font-monospace btn-sm px-4 fw-bold text-dark"
        >
          EXECUTE_COMMIT
        </button>
      </div>
    </form>
  </div>
</div>
