<%- layout('boilerplate') %>

<!-- Full-Screen Matrix Content Container -->
<div class="d-flex flex-column flex-grow-1 w-100 py-5" style="background-color: #0f172a;">
    <div class="container text-white">
        
        <!-- Workspace System Dashboard Header -->
        <div class="d-flex flex-wrap justify-content-between align-items-center pb-4 mb-5 border-bottom border-secondary border-opacity-20">
            <div>
                <h1 class="h2 fw-black text-white tracking-tight mb-1">Knowledge Ledger</h1>
                <p class="text-info font-monospace small mb-0">// Active Cluster Workspace</p>
            </div>
            <div>
                <!-- New Accent Button -->
                <button class="btn btn-info font-monospace px-4 py-2 small shadow-sm fw-bold text-dark">
                    + NEW_NOTE_NODE
                </button>
            </div>
        </div>

        <!-- Active Grid Matrix Frame -->
        <div class="row g-4">
            <% if (notes && notes.length > 0) { %>
                <% notes.forEach(note => { %>
                    <div class="col-md-6 col-lg-4">
                        <!-- Dark Slate Note Card Block -->
                        <div class="card h-100 note-card border-0" style="background-color: #1e293b;">
                            <div class="card-body d-flex flex-column p-4">
                                
                                <!-- Card Meta Header Block -->
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <span class="badge font-monospace text-info px-2.5 py-1.5 small border border-info border-opacity-25" style="background-color: rgba(56, 189, 248, 0.05);">
                                        <%= note.folderName || 'Root_Directory' %>
                                    </span>
                                    <% if (note.isPinned) { %>
                                        <span class="text-warning font-monospace small" title="Pinned Node" style="font-size: 0.8rem;">
                                            ⚡ PIN_LOCKED
                                        </span>
                                    <% } %>
                                </div>

                                <!-- Content Display Elements -->
                                <h3 class="h5 fw-bold text-white tracking-tight mb-2">
                                    <%= note.title %>
                                </h3>
                                
                                <p class="text-secondary small flex-grow-1 mb-4" style="line-height: 1.6; color: #94a3b8 !important;">
                                    <%= note.plainTextSummary %>
                                </p>

                                <!-- Taxonomy Tag Metrics -->
                                <% if (note.tags && note.tags.length > 0) { %>
                                    <div class="d-flex flex-wrap gap-1.5 mb-4">
                                        <% note.tags.forEach(tag => { %>
                                            <span class="font-monospace me-2 small px-2 py-0.5 rounded text-secondary border border-secondary border-opacity-20" style="font-size: 0.75rem; background-color: rgba(148, 163, 184, 0.05);">
                                                #<%= tag %>
                                            </span>
                                        <% }) %>
                                    </div>
                                <% } %>

                                <!-- System Infrastructure Footer Row -->
                                <div class="d-flex justify-content-between align-items-center pt-3 mt-auto border-top border-secondary border-opacity-20 font-monospace text-muted" style="font-size: 0.75rem; color: #64748b !important;">
                                    <span>WT_COUNT: <%= note.wordCount %></span>
                                    <span>SYNCED: <%= note.updatedAt %></span>
                                </div>

                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <!-- Zero State System Fallback -->
                <div class="col-12 text-center py-5">
                    <div class="p-5 border border-dashed border-secondary border-opacity-30 rounded" style="background-color: #1e293b;">
                        <p class="text-secondary font-monospace mb-0">System memory pool empty. No operational notes allocated.</p>
                    </div>
                </div>
            <% } %>
        </div>

    </div>
</div>
